{
    "name": "mlj-net/php-api",
    "description": "MLJ NET PHP Backend API - Hybrid Node.js + PHP Platform",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "firebase/php-jwt": "^6.10",
        "guzzlehttp/guzzle": "^7.8",
        "monolog/monolog": "^3.7",
        "vlucas/phpdotenv": "^5.6",
        "symfony/console": "^6.4",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-openssl": "*",
        "ext-mbstring": "*"
    },
    "autoload": {
        "psr-4": {
            "MLJNet\\": "src/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('config/.env') || copy('config/.env.example', 'config/.env');\""
        ]
    },
    "config": {
        "allow-plugins": {},
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
