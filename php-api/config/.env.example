# MLJ NET PHP API - Environment Configuration
# Copy this file to .env and adjust values

# Database (shared SQLite with Node.js)
DB_PATH=../db/custom.db

# JWT (must match Node.js .env)
JWT_SECRET=change-this-to-a-random-secret
SESSION_SECRET=change-this-to-a-random-secret

# GenieACS
GENIEACS_NBI_URL=http://127.0.0.1:7557
GENIEACS_NBI_USERNAME=
GENIEACS_NBI_PASSWORD=
GENIEACS_CWMP_PORT=7547
GENIEACS_NBI_PORT=7557
GENIEACS_FS_PORT=7567

# MikroTik (optional)
MIKROTIK_HOST=192.168.1.1
MIKROTIK_PORT=8728
MIKROTIK_USERNAME=admin
MIKROTIK_PASSWORD=

# App
APP_ENV=production
APP_DEBUG=false
LOG_PATH=../../logs/php-api.log
