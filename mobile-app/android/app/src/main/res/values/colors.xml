<?xml version="1.0" encoding="utf-8"?>
<!--
  colors.xml - MLJ NET Dark Theme Color Palette
  
  This defines all colors used throughout the Android app,
  matching the web app's dark navy theme with cyan accents.
-->
<resources>
    <!-- Primary Colors -->
    <color name="color_primary">#06b6d4</color>
    <color name="color_primary_dark">#0891b2</color>
    <color name="color_primary_light">#22d3ee</color>
    <color name="color_primary_variant">#0e7490</color>
    
    <!-- Background Colors -->
    <color name="color_background">#0a0e1a</color>
    <color name="color_surface">#111827</color>
    <color name="color_surface_variant">#1f2937</color>
    <color name="color_card">#111827</color>
    
    <!-- Text Colors -->
    <color name="color_text_primary">#f8fafc</color>
    <color name="color_text_secondary">#94a3b8</color>
    <color name="color_text_disabled">#475569</color>
    <color name="color_text_on_primary">#0a0e1a</color>
    
    <!-- Status Bar -->
    <color name="color_status_bar">#0a0e1a</color>
    <color name="color_navigation_bar">#0a0e1a</color>
    
    <!-- Splash Screen -->
    <color name="color_splash_background">#0a0e1a</color>
    <color name="color_splash_accent">#06b6d4</color>
    
    <!-- Error / Warning / Success -->
    <color name="color_error">#ef4444</color>
    <color name="color_warning">#f59e0b</color>
    <color name="color_success">#10b981</color>
    
    <!-- Border / Divider -->
    <color name="color_border">#1e293b</color>
    <color name="color_divider">#1e293b</color>
</resources>
