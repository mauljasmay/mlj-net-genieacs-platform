# ============================================================================
# MLJ NET GenieACS Platform - Environment Configuration
# Copy this file to .env and fill in your values
#   cp .env.example .env
# ============================================================================

# ----------------------------------------------------------------------------
# Database (SQLite)
# Relative path is auto-resolved to absolute at runtime by src/lib/db.ts
# You can also use an absolute path: file:/home/user/mljnet-platform/db/custom.db
# ----------------------------------------------------------------------------
DATABASE_URL="file:./db/custom.db"

# ----------------------------------------------------------------------------
# GenieACS NBI API
# Use "http://127.0.0.1:7557" for local mode (GenieACS on same server)
# Use "http://REMOTE_IP:7557" for remote/external GenieACS server
# ----------------------------------------------------------------------------
GENIEACS_NBI_URL="http://127.0.0.1:7557"
GENIEACS_NBI_USERNAME=""
GENIEACS_NBI_PASSWORD=""

# ----------------------------------------------------------------------------
# GenieACS Service Ports
# Only needed if GenieACS is running locally on this server
# ----------------------------------------------------------------------------
GENIEACS_CWMP_PORT=7547
GENIEACS_NBI_PORT=7557
GENIEACS_FS_PORT=7567
GENIEACS_DASHBOARD_PORT=3000

# ----------------------------------------------------------------------------
# Authentication
# Generate secrets with: openssl rand -base64 32
# These are auto-generated by setup.sh if .env does not exist
# ----------------------------------------------------------------------------
JWT_SECRET="change-me-generate-with-openssl-rand-base64-32"
SESSION_SECRET="change-me-generate-with-openssl-rand-base64-32"

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="production"
PORT=3000
